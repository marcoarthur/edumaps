use Mojo::Base -signatures;
use Rex -feature => [qw(1.6 exec_autodie)];
use Mojo::File qw(path);

user 'root';
set edumaps_dir => '/opt/edumaps';
set local_dir => path("../../../")->realpath;
set mode => 'development';
set db_password => $ENV{EDUMAPS_DB_PASS} || 'change_me';
set db_user => $ENV{EDUMAPS_DB_USER} || 'edumaps';
set db_name => $ENV{EDUMAPS_DB_NAME} || 'edumaps_dev';

group all => qw( backend.edumaps database.edumaps );

desc "Update Debian, install minimum dev tools, Rsync your code";
task "prepare" => group => all => sub {
  # Update system and install basics
  update_package_db();

  # Install dev tools (build-essential, git, etc.)
  pkg $_, ensure => 'present' for ( 
    "build-essential",
    "git",
    "ca-certificates",
    "rsync",
    "curl",
  );

  my $server = lc(run q{ hostname });
  Rex::Logger::info("Syncing $server... ");
  my $gitignore = get('local_dir') . "/.gitignore";

  #
  # Copying from your local code base
  #
  # TODO: a selection from Git (+tags) OR Local Code 

  LOCAL {
    run sprintf(qq{
      rsync -avz --filter=':- $gitignore' -e ssh %s/ %s.edumaps:%s/
    }, get('local_dir'), $server, get('edumaps_dir'));
  };
};

desc "Configure and Install Perl backend";
task deploy_backend_dev => 'backend.edumaps' => sub {
  pkg $_, ensure => 'present' for qw<
    libpq-dev build-essential cpanminus  
    libio-socket-ssl-perl liblwp-protocol-https-perl carton
  >;

  my $path = get('edumaps_dir') . '/backend';

  # Set configuration for edumaps
  file "$path/edu_maps.conf",
    content => template(
      "./files/edumaps_db.conf",
      {
        db_pass => get('db_password') || 'change_me',
        db_user => get('db_user') || 'edumaps',
      }
    )
  ;

  chomp(my $carton = run qq{which carton});

  # TEMPORARY HACK:
  # backend dependencies are currently generated by Dist::Zilla
  # during build and are not versioned.
  # We copy the generated cpanfile until a real versioned
  # cpanfile is introduced.
  #
  my @generated = glob("$path/EduMaps-*/cpanfile");
  die "Generated cpanfile not found after rsync" unless @generated;
  run qq{cp "$generated[-1]" "$path/cpanfile"};
  my $file = path($path, 'cpanfile')->to_string();

  # Another dirty hack, removing references for modules that should never get there
  # in first place (Seems AutoPrereqs has many problems)
  delete_lines_matching $file => "EduMaps";
  delete_lines_matching $file => "Contextable";
  run qq{$carton install}, cwd => $path;

  #
  # Morbo Service File
  #
  file "/etc/systemd/system/edumaps-web.service",
    content => template(
      './files/edumaps-web.service',
      {
        mojo_mode => get ('mode'),
        morbo_port => 3000,
        carton_path => $carton,
        edumaps_path => path($path,'edu_maps.pl')->to_string,
        work_dir => $path,
      }
    ),
    on_change => sub {
      run q{systemctl daemon-reload};
      run q{systemctl enable --now edumaps-web};
    }
  ;

  service 'edumaps-web' => 'restart';
};

desc "Configure and Install Minion Jobs and its dependencies";
task deploy_minion_dev => 'backend.edumaps' => sub {
  pkg $_, ensure => 'present' for qw(
    cmake
    make
    gcc
    libzip-dev
    zlib1g-dev
    libexpat1-dev
    libminizip-dev
  );

  run q{
    git clone https://github.com/brechtsanders/xlsxio.git /opt/xlsxio
  }, unless => 'test -d /opt/xlsxio';

  run q{
    git checkout 0.2.36
  }, cwd => '/opt/xlsxio';

  run q{
    make
  }, cwd => '/opt/xlsxio';

  run q{
    cp xlsxio_xlsx2csv /usr/local/bin/xlsx2csv_fast
  }, cwd => '/opt/xlsxio';

  #
  # Minion Service File
  #
  chomp(my $carton = run qq{which carton});
  my $path = get('edumaps_dir') . '/backend';
  file "/etc/systemd/system/edumaps-minion.service",
    content => template(
      './files/edumaps-minion.service',
      {
        mojo_mode => get ('mode'),
        edumaps_path => path($path,'edu_maps.pl')->to_string,
        work_dir => $path,
        carton_path => $carton,
      }
    ),
    on_change => sub {
      run q{systemctl daemon-reload};
      run q{systemctl enable --now edumaps-minion};
    }
  ;

  service 'edumaps-minion' => 'restart';
};

desc "Configure and Install (Svelte/Vite) Frontend";
task deploy_frontend_dev => 'backend.edumaps' => sub {
  # NodeSource repo (Node 22 LTS)
  run q{
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
  }, unless => "which npm";

  run qq{apt-get -y update};
  pkg 'nodejs', ensure => 'present';
  pkg 'npm', ensure => 'present';

  my $frontend_path = get('edumaps_dir') . "/frontend/map_app";
  Rex::Logger::info("Installing frontend dependencies");
  run q{npm install}, cwd => $frontend_path;
  Rex::Logger::info("Building frontend");
  run q{npm run build}, cwd => $frontend_path;

  #
  # Vite dev server service
  #

  file "/etc/systemd/system/edumaps-frontend.service",
    content => template(
      './files/edumaps-frontend.service',
      {
        frontend_path => $frontend_path,
      }
    ),
    on_change => sub {
      run q{systemctl daemon-reload};
      run q{systemctl enable --now edumaps-frontend.service};
    }
  ;

  service 'edumaps-frontend' => 'restart';
};

desc "Configure and Install PostgreSQL/PostGIS/Sqitch";
task deploy_db_dev => 'database.edumaps' => sub {
  my $pg_version   = 16;
  my $db_name      = get('db_name') || 'edumaps_dev';
  my $db_user      = get('db_user') || 'edumaps';
  my $db_pass      = get('db_password') || 'change_me';
  my $repo_path    = get('edumaps_dir');

  #
  # 0. configure PostgreSQL official repository
  #

  pkg $_, ensure => 'present' for (qw[ 
    curl
    gnupg
    ca-certificates
    lsb-release
    rsync
    sudo
  ],
  "postgresql-$pg_version-ogr-fdw"
  );

  run q{
    install -d /usr/share/postgresql-common/pgdg
  };

  run q{
    curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc \
    | gpg --dearmor \
    -o /usr/share/postgresql-common/pgdg/apt.postgresql.org.gpg
  }, unless => 'test -f /usr/share/postgresql-common/pgdg/apt.postgresql.org.gpg';

  file '/etc/apt/sources.list.d/pgdg.list',
  content => q{
    deb [signed-by=/usr/share/postgresql-common/pgdg/apt.postgresql.org.gpg] http://apt.postgresql.org/pub/repos/apt bookworm-pgdg main
  };

  run q{ apt-get update };

  #
  # 1. install packages
  #

  pkg $_, ensure => 'present' for (
    qw(
      build-essential
      libpq-dev
      sqitch
    ),
    "postgresql-$pg_version",
    "postgresql-client-$pg_version",
    "postgresql-$pg_version-postgis-3",
    "postgresql-$pg_version-postgis-3-scripts",
  );

  #
  # 2. enable + start PostgreSQL
  #

  service 'postgresql' => 'start';
  service 'postgresql' => 'enable';

  #
  # 3. configure PostgreSQL TCP access
  #

  append_if_no_such_line
  "/etc/postgresql/$pg_version/main/postgresql.conf",
  "listen_addresses = '*'"
  ;

  append_if_no_such_line "/etc/postgresql/$pg_version/main/pg_hba.conf",
  "host all all 0.0.0.0/0 scram-sha-256"
  ;

  #
  # 4. create development user
  #

  run qq{
    sudo -u postgres psql -tc "
    SELECT 1
    FROM pg_roles
    WHERE rolname = '$db_user'
    " | grep -q 1
  },
  unless => qq{
    sudo -u postgres psql -tc "
    SELECT 1
    FROM pg_roles
    WHERE rolname = '$db_user'
    " | grep -q 1
  },
  auto_die => 0,
  ;

  run qq{
    sudo -u postgres psql -c "
    CREATE USER $db_user
    WITH PASSWORD '$db_pass'
    CREATEDB;
    "
  },
  unless => qq{
    sudo -u postgres psql -tc "
    SELECT 1
    FROM pg_roles
    WHERE rolname = '$db_user'
    " | grep -q 1
  },
  auto_die => 0,
  ;

  run qq{
    sudo -u postgres psql -c "
      ALTER ROLE $db_user
      WITH SUPERUSER;
    "
  };

  #
  # 5. create database
  #

  run qq{
    sudo -u postgres createdb -O $db_user $db_name
  },
  unless => qq{
    sudo -u postgres psql -lqt | cut -d '\|' -f 1 | grep -qw $db_name
  };

  #
  # 6 Move datasets to /data
  #
  
  LOCAL {
    run qq{
      rsync -avz -e ssh ~/Data/edumaps_data/ database.edumaps:/data/
    };
  };

  #
  # 7. run sqitch deploy
  #
  
  run qq{
    sqitch deploy db:pg://$db_user:$db_pass\@localhost/$db_name
  }, cwd => "$repo_path/data_pipeline";

  #
  # 8. restart postgresql
  #
  service 'postgresql' => 'restart';
};

__END__

=head1 NAME

Rexfile - Development deployment automation for EduMaps infrastructure

=head1 DESCRIPTION

This Rexfile provisions and deploys the EduMaps development stack across
multiple hosts.

Current managed components:

=over 4

=item *

Perl backend application (Mojolicious + Minion)

=item *

Svelte/Vite frontend application

=item *

PostgreSQL + PostGIS + Sqitch database infrastructure

=item *

Systemd service definitions for backend and frontend processes

=back

The deployment model is development-oriented and intentionally syncs the
local working tree directly to remote hosts using rsync.

This means uncommitted local changes are deployed as-is.

=head1 ARCHITECTURE

The deployment currently assumes two hosts:

=over 4

=item *

C<backend.edumaps>

Responsible for:

=over 2

=item * Perl backend

=item * frontend build/runtime

=item * systemd services

=back

=item *

C<database.edumaps>

Responsible for:

=over 2

=item * PostgreSQL

=item * PostGIS

=item * Sqitch migrations

=item * spatial datasets

=back

=back

=head1 IMPORTANT NOTES

=head2 Source of Truth

The local working tree is considered the primary source of truth.

Code is synchronized directly from the developer machine using rsync,
instead of cloning from Git repositories on remote hosts.

=head2 Dist::Zilla Dependency Metadata

The backend currently depends on dependency metadata generated by
Dist::Zilla during build time.

Because no versioned C<cpanfile> exists yet, deployment temporarily copies
the generated C<cpanfile> from build artifacts.

This is a known technical debt and should eventually be replaced by a
real versioned C<cpanfile> committed to the repository.

=head2 Development Environment

This setup is optimized for development environments.

Current choices intentionally favor convenience over production hardening,
including:

=over 4

=item *

Morbo development server

=item *

PostgreSQL superuser permissions

=item *

wide PostgreSQL network access

=item *

direct rsync deployment

=back

These settings should not be reused unchanged in production environments.

=head1 TASKS

=head2 prepare

Installs base operating system dependencies and synchronizes the local
repository to remote hosts.

=head2 deploy_backend_dev

Configures and deploys the Perl backend application and related systemd
services.

=head2 deploy_frontend_dev

Builds and deploys the Svelte/Vite frontend application.

=head2 deploy_db_dev

Installs and configures PostgreSQL/PostGIS infrastructure and executes
Sqitch migrations.

=head1 ENVIRONMENT VARIABLES

=over 4

=item * C<EDUMAPS_DB_PASS>

Database password

=item * C<EDUMAPS_DB_USER>

Database username

=item * C<EDUMAPS_DB_NAME>

Database name

=back

=head1 AUTHOR

EduMaps development infrastructure

=cut
